{
  "name": "agent-fight-club",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "arena": "node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:scripted": "node --experimental-strip-types scripts/run-arena-preset.ts scripted",
    "arena:claude": "AFC_CLAUDE_AGENT_IDS=ironclad node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:claude:all": "node --experimental-strip-types scripts/run-arena-preset.ts claude",
    "arena:claude:smoke": "AFC_CLAUDE_AGENT_IDS=ironclad AFC_FIGHT_IDS=live-001 AFC_CLAUDE_TIMEOUT_MS=300000 node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:codex": "AFC_CODEX_AGENT_IDS=ghostwire node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:codex:all": "node --experimental-strip-types scripts/run-arena-preset.ts codex",
    "arena:codex:smoke": "AFC_CODEX_AGENT_IDS=ghostwire AFC_FIGHT_IDS=live-001 AFC_CODEX_TIMEOUT_MS=300000 node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:easy": "node --experimental-strip-types scripts/run-arena-preset.ts versus",
    "arena:gemini": "AFC_GEMINI_AGENT_IDS=blackboxer node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:gemini:all": "node --experimental-strip-types scripts/run-arena-preset.ts gemini",
    "arena:gemini:smoke": "AFC_GEMINI_AGENT_IDS=blackboxer AFC_FIGHT_IDS=live-002 AFC_GEMINI_TIMEOUT_MS=300000 node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:multiverse": "AFC_CODEX_AGENT_IDS=ghostwire AFC_CLAUDE_AGENT_IDS=ironclad AFC_GEMINI_AGENT_IDS=blackboxer node --experimental-strip-types scripts/run-live-arena.ts",
    "arena:publish": "node --experimental-strip-types scripts/publish-live-arena.ts",
    "arena:publish:claude": "node --experimental-strip-types scripts/publish-live-arena.ts claude",
    "arena:publish:codex": "node --experimental-strip-types scripts/publish-live-arena.ts codex",
    "arena:publish:gemini": "node --experimental-strip-types scripts/publish-live-arena.ts gemini",
    "arena:publish:multiverse": "node --experimental-strip-types scripts/publish-live-arena.ts multiverse",
    "arena:publish:versus": "node --experimental-strip-types scripts/publish-live-arena.ts versus",
    "arena:versus": "node --experimental-strip-types scripts/run-arena-preset.ts versus",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "publish:contract": "node --experimental-strip-types scripts/publish-provider-contract.ts",
    "typecheck": "tsc --noEmit",
    "report": "node --experimental-strip-types scripts/season-report.ts",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
